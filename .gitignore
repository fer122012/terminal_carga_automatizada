# pero ignora configuraciones personales de cada desarrollador.
.vscode/settings.json
.vscode/extensions.json
 
# ── WSL / Linux ────────────────────────────────────────────────────────
*~
.DS_Store
 
# ── Valgrind / sanitizers ───────────────────────────────────────────────
valgrind-out.txt
*.memcheck